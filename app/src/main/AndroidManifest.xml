<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.INTERNET" />

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.NutriGuideProject">
        <activity
            android:name=".ui.welcome.WelcomeActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity
            android:name=".ui.auth.AuthActivity"
            android:exported="false" />

        <activity
            android:name=".ui.user.dashboard.DashboardActivity"
            android:exported="false"
            android:launchMode="singleTop" />

        <activity
            android:name=".ui.user.log.LogActivity"
            android:exported="false"
            android:launchMode="singleTop" />

        <activity
            android:name=".ui.user.menu.MenuActivity"
            android:exported="false"
            android:launchMode="singleTop" />

        <activity
            android:name=".ui.user.article.ArticleActivity"
            android:exported="false" />

        <activity
            android:name=".ui.user.recommendation.RecommendationActivity"
            android:exported="false"
            android:launchMode="singleTop" />

        <activity
            android:name=".ui.user.profile.ProfileActivity"
            android:exported="false"
            android:launchMode="singleTop" />

        <activity
            android:name=".ui.user.profile.ProfileEditActivity"
            android:exported="false" />

        <activity
            android:name=".ui.user.chart.ChartActivity"
            android:exported="false"
            android:launchMode="singleTop" />

        <activity
            android:name=".ui.admin.AdminDashboardActivity"
            android:exported="false"
            android:launchMode="singleTop" />

        <activity
            android:name=".ui.admin.ManageFoodActivity"
            android:exported="false"
            android:launchMode="singleTop" />

        <activity
            android:name=".ui.admin.AdminSettingsActivity"
            android:exported="false"
            android:launchMode="singleTop" />

        <activity
            android:name=".ui.admin.ManageArticleActivity"
            android:exported="false" />

        <activity
            android:name=".ui.admin.UserListActivity"
            android:exported="false" />
    </application>

</manifest>
