<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/dashboardRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/screen_bg"
    android:orientation="vertical"
    tools:context=".ui.dashboard.DashboardActivity">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

        <!-- Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_dashboard_header"
            android:orientation="vertical"
            android:paddingHorizontal="20dp"
            android:paddingTop="24dp"
            android:paddingBottom="24dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/dash_greeting"
                        android:textColor="@color/text_on_dark_muted"
                        android:textSize="14sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/dash_user_name"
                        android:textColor="@color/text_on_dark"
                        android:textSize="22sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <FrameLayout
                    android:layout_width="42dp"
                    android:layout_height="42dp"
                    android:background="@drawable/bg_circle_icon_dark">

                    <ImageView
                        android:layout_width="22dp"
                        android:layout_height="22dp"
                        android:layout_gravity="center"
                        android:contentDescription="@null"
                        android:src="@drawable/ic_bell" />
                </FrameLayout>
            </LinearLayout>

            <!-- Calorie card -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:background="@drawable/bg_calorie_card"
                android:orientation="vertical"
                android:padding="18dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/dash_calorie_title"
                        android:textColor="@color/text_on_dark_muted"
                        android:textSize="14sp" />

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_badge_green"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:paddingHorizontal="10dp"
                        android:paddingVertical="5dp">

                        <ImageView
                            android:layout_width="14dp"
                            android:layout_height="14dp"
                            android:layout_marginEnd="4dp"
                            android:contentDescription="@null"
                            android:src="@drawable/ic_check" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/dash_calorie_badge"
                            android:textColor="@color/badge_green_text"
                            android:textSize="12sp"
                            android:textStyle="bold" />
                    </LinearLayout>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:gravity="bottom"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/dash_calorie_value"
                        android:textColor="@color/text_on_dark"
                        android:textSize="40sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="6dp"
                        android:layout_marginBottom="8dp"
                        android:text="@string/dash_calorie_total"
                        android:textColor="@color/text_on_dark_muted"
                        android:textSize="15sp" />
                </LinearLayout>

                <ProgressBar
                    android:id="@+id/calorieProgress"
                    style="?android:attr/progressBarStyleHorizontal"
                    android:layout_width="match_parent"
                    android:layout_height="8dp"
                    android:layout_marginTop="12dp"
                    android:max="100"
                    android:progress="72"
                    android:progressDrawable="@drawable/bg_progress_calorie" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/dash_calorie_percent"
                        android:textColor="@color/text_on_dark_muted"
                        android:textSize="12sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/dash_calorie_remaining"
                        android:textColor="@color/text_on_dark_muted"
                        android:textSize="12sp" />
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>

        <!-- Body -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                style="@style/SectionTitle"
                android:text="@string/dash_quick_action" />

            <!-- Quick action card -->
            <LinearLayout
                android:id="@+id/cardLogFood"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:background="@drawable/bg_card_green"
                android:gravity="center"
                android:orientation="vertical"
                android:padding="20dp">

                <FrameLayout
                    android:layout_width="52dp"
                    android:layout_height="52dp"
                    android:background="@drawable/bg_icon_tile">

                    <ImageView
                        android:layout_width="26dp"
                        android:layout_height="26dp"
                        android:layout_gravity="center"
                        android:contentDescription="@null"
                        android:src="@drawable/ic_apple_filled" />
                </FrameLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:text="@string/dash_log_food"
                    android:textColor="@color/text_dark"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:text="@string/dash_log_food_sub"
                    android:textColor="@color/text_muted"
                    android:textSize="13sp" />
            </LinearLayout>

            <TextView
                style="@style/SectionTitle"
                android:layout_marginTop="22dp"
                android:text="@string/dash_nutrition_summary" />

            <!-- Nutrition summary row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:baselineAligned="false"
                android:orientation="horizontal">

                <!-- Protein -->
                <LinearLayout
                    style="@style/NutritionCard">

                    <View style="@style/NutritionDot" />

                    <TextView
                        style="@style/NutritionValue"
                        android:text="52g" />

                    <TextView
                        style="@style/NutritionLabel"
                        android:text="@string/dash_protein" />

                    <TextView
                        style="@style/NutritionPercent"
                        android:text="87%" />
                </LinearLayout>

                <Space
                    android:layout_width="10dp"
                    android:layout_height="1dp" />

                <!-- Karbohidrat -->
                <LinearLayout
                    style="@style/NutritionCard">

                    <View style="@style/NutritionDot" />

                    <TextView
                        style="@style/NutritionValue"
                        android:text="180g" />

                    <TextView
                        style="@style/NutritionLabel"
                        android:text="@string/dash_carbs" />

                    <TextView
                        style="@style/NutritionPercent"
                        android:text="75%" />
                </LinearLayout>

                <Space
                    android:layout_width="10dp"
                    android:layout_height="1dp" />

                <!-- Lemak -->
                <LinearLayout
                    style="@style/NutritionCard">

                    <View style="@style/NutritionDot" />

                    <TextView
                        style="@style/NutritionValue"
                        android:text="45g" />

                    <TextView
                        style="@style/NutritionLabel"
                        android:text="@string/dash_fat" />

                    <TextView
                        style="@style/NutritionPercent"
                        android:text="82%" />
                </LinearLayout>
            </LinearLayout>

            <!-- Food log header -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="22dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    style="@style/SectionTitle"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:text="@string/dash_food_log_today" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/dash_see_all"
                    android:textColor="@color/green_dark"
                    android:textSize="13sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <!-- Sarapan -->
            <LinearLayout style="@style/FoodLogCard">

                <FrameLayout style="@style/FoodLogIconTile">

                    <ImageView
                        style="@style/FoodLogIcon"
                        android:src="@drawable/ic_restaurant" />
                </FrameLayout>

                <LinearLayout style="@style/FoodLogText">

                    <TextView
                        style="@style/FoodLogName"
                        android:text="Sarapan" />

                    <TextView
                        style="@style/FoodLogDesc"
                        android:text="Nasi Goreng + Telur" />
                </LinearLayout>

                <LinearLayout style="@style/FoodLogTrailing">

                    <TextView
                        style="@style/FoodLogKcal"
                        android:text="450 kkal" />

                    <TextView
                        style="@style/FoodLogTime"
                        android:text="08:00" />
                </LinearLayout>
            </LinearLayout>

            <!-- Makan Siang -->
            <LinearLayout style="@style/FoodLogCard">

                <FrameLayout style="@style/FoodLogIconTile">

                    <ImageView
                        style="@style/FoodLogIcon"
                        android:src="@drawable/ic_restaurant" />
                </FrameLayout>

                <LinearLayout style="@style/FoodLogText">

                    <TextView
                        style="@style/FoodLogName"
                        android:text="Makan Siang" />

                    <TextView
                        style="@style/FoodLogDesc"
                        android:text="Ayam Bakar + Sayur" />
                </LinearLayout>

                <LinearLayout style="@style/FoodLogTrailing">

                    <TextView
                        style="@style/FoodLogKcal"
                        android:text="650 kkal" />

                    <TextView
                        style="@style/FoodLogTime"
                        android:text="12:30" />
                </LinearLayout>
            </LinearLayout>

            <!-- Snack -->
            <LinearLayout style="@style/FoodLogCard">

                <FrameLayout style="@style/FoodLogIconTile">

                    <ImageView
                        style="@style/FoodLogIcon"
                        android:src="@drawable/ic_apple_filled" />
                </FrameLayout>

                <LinearLayout style="@style/FoodLogText">

                    <TextView
                        style="@style/FoodLogName"
                        android:text="Snack" />

                    <TextView
                        style="@style/FoodLogDesc"
                        android:text="Pisang + Susu" />
                </LinearLayout>

                <LinearLayout style="@style/FoodLogTrailing">

                    <TextView
                        style="@style/FoodLogKcal"
                        android:text="350 kkal" />

                    <TextView
                        style="@style/FoodLogTime"
                        android:text="15:00" />
                </LinearLayout>
            </LinearLayout>

            <!-- Article header -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="22dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    style="@style/SectionTitle"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:text="@string/dash_article_section" />

                <TextView
                    android:id="@+id/seeAllArticles"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="?attr/selectableItemBackground"
                    android:text="@string/dash_see_all"
                    android:textColor="@color/green_dark"
                    android:textSize="13sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <!-- Article card -->
            <LinearLayout
                android:id="@+id/cardArticle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:background="@drawable/bg_card"
                android:orientation="vertical">

                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="120dp"
                    android:background="@drawable/bg_icon_tile">

                    <ImageView
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:layout_gravity="center"
                        android:contentDescription="@null"
                        android:src="@drawable/ic_book" />
                </FrameLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:background="@drawable/bg_tag"
                            android:paddingHorizontal="10dp"
                            android:paddingVertical="4dp"
                            android:text="@string/dash_article_tag"
                            android:textColor="@color/badge_green_text"
                            android:textSize="11sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="10dp"
                            android:text="@string/dash_article_read"
                            android:textColor="@color/text_muted"
                            android:textSize="12sp" />
                    </LinearLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:text="@string/dash_article_title"
                        android:textColor="@color/text_dark"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:text="@string/dash_article_desc"
                        android:textColor="@color/text_muted"
                        android:textSize="13sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:text="@string/dash_article_more"
                        android:textColor="@color/green_dark"
                        android:textSize="13sp"
                        android:textStyle="bold" />
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>
        </LinearLayout>
    </ScrollView>

    <!-- Bottom navigation bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/surface"
        android:elevation="12dp"
        android:orientation="horizontal"
        android:paddingHorizontal="8dp"
        android:paddingVertical="8dp">

        <!-- Home (active) -->
        <LinearLayout
            android:id="@+id/navHome"
            style="@style/NavItem">

            <LinearLayout
                style="@style/NavIconWrap"
                android:background="@drawable/bg_nav_active">

                <ImageView
                    style="@style/NavIcon"
                    android:contentDescription="@string/nav_home"
                    android:src="@drawable/ic_home"
                    app:tint="@color/nav_active" />
            </LinearLayout>

            <TextView
                style="@style/NavLabel"
                android:text="@string/nav_home"
                android:textColor="@color/nav_active"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Log -->
        <LinearLayout
            android:id="@+id/navLog"
            style="@style/NavItem">

            <LinearLayout style="@style/NavIconWrap">

                <ImageView
                    style="@style/NavIcon"
                    android:contentDescription="@string/nav_log"
                    android:src="@drawable/ic_apple_filled"
                    app:tint="@color/nav_inactive" />
            </LinearLayout>

            <TextView
                style="@style/NavLabel"
                android:text="@string/nav_log"
                android:textColor="@color/nav_inactive" />
        </LinearLayout>

        <!-- Menu -->
        <LinearLayout
            android:id="@+id/navMenu"
            style="@style/NavItem">

            <LinearLayout style="@style/NavIconWrap">

                <ImageView
                    style="@style/NavIcon"
                    android:contentDescription="@string/nav_menu"
                    android:src="@drawable/ic_restaurant"
                    app:tint="@color/nav_inactive" />
            </LinearLayout>

            <TextView
                style="@style/NavLabel"
                android:text="@string/nav_menu"
                android:textColor="@color/nav_inactive" />
        </LinearLayout>

        <!-- Grafik -->
        <LinearLayout
            android:id="@+id/navChart"
            style="@style/NavItem">

            <LinearLayout style="@style/NavIconWrap">

                <ImageView
                    style="@style/NavIcon"
                    android:contentDescription="@string/nav_chart"
                    android:src="@drawable/ic_chart"
                    app:tint="@color/nav_inactive" />
            </LinearLayout>

            <TextView
                style="@style/NavLabel"
                android:text="@string/nav_chart"
                android:textColor="@color/nav_inactive" />
        </LinearLayout>

        <!-- Profil -->
        <LinearLayout
            android:id="@+id/navProfile"
            style="@style/NavItem">

            <LinearLayout style="@style/NavIconWrap">

                <ImageView
                    style="@style/NavIcon"
                    android:contentDescription="@string/nav_profile"
                    android:src="@drawable/ic_person"
                    app:tint="@color/nav_inactive" />
            </LinearLayout>

            <TextView
                style="@style/NavLabel"
                android:text="@string/nav_profile"
                android:textColor="@color/nav_inactive" />
        </LinearLayout>
    </LinearLayout>
</LinearLayout>

