<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/adminRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/screen_bg"
    android:orientation="vertical"
    tools:context=".ui.admin.AdminDashboardActivity">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Header -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_dashboard_header"
                android:orientation="vertical"
                android:paddingHorizontal="20dp"
                android:paddingTop="24dp"
                android:paddingBottom="24dp">

                <FrameLayout
                    android:layout_width="46dp"
                    android:layout_height="46dp"
                    android:background="@drawable/bg_circle_icon_dark">

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:layout_gravity="center"
                        android:contentDescription="@null"
                        android:src="@drawable/ic_settings" />
                </FrameLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="@string/admin_title"
                    android:textColor="@color/text_on_dark"
                    android:textSize="26sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:text="@string/admin_subtitle"
                    android:textColor="@color/text_on_dark_muted"
                    android:textSize="14sp" />
            </LinearLayout>

            <!-- Body -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <!-- Stat grid row 1 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:baselineAligned="false"
                    android:orientation="horizontal">

                    <LinearLayout style="@style/StatCard">
                        <FrameLayout android:layout_width="40dp" android:layout_height="40dp" android:background="@drawable/bg_icon_tile">
                            <ImageView android:layout_width="22dp" android:layout_height="22dp" android:layout_gravity="center" android:contentDescription="@null" android:src="@drawable/ic_group" />
                        </FrameLayout>
                        <TextView style="@style/StatLabel" android:text="@string/admin_stat_users" />
                        <TextView android:id="@+id/tvStatUsers" style="@style/StatValue" android:text="@string/admin_stat_users_value" />
                        <TextView style="@style/StatBadge" android:text="@string/admin_stat_users_badge" />
                    </LinearLayout>

                    <Space android:layout_width="12dp" android:layout_height="1dp" />

                    <LinearLayout style="@style/StatCard">
                        <FrameLayout android:layout_width="40dp" android:layout_height="40dp" android:background="@drawable/bg_icon_tile">
                            <ImageView android:layout_width="22dp" android:layout_height="22dp" android:layout_gravity="center" android:contentDescription="@null" android:src="@drawable/ic_database" />
                        </FrameLayout>
                        <TextView style="@style/StatLabel" android:text="@string/admin_stat_food" />
                        <TextView android:id="@+id/tvStatFood" style="@style/StatValue" android:text="@string/admin_stat_food_value" />
                        <TextView style="@style/StatBadge" android:text="@string/admin_stat_food_badge" />
                    </LinearLayout>
                </LinearLayout>

                <!-- Stat grid row 2 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:baselineAligned="false"
                    android:orientation="horizontal">

                    <LinearLayout style="@style/StatCard">
                        <FrameLayout android:layout_width="40dp" android:layout_height="40dp" android:background="@drawable/bg_icon_tile">
                            <ImageView android:layout_width="22dp" android:layout_height="22dp" android:layout_gravity="center" android:contentDescription="@null" android:src="@drawable/ic_document" />
                        </FrameLayout>
                        <TextView style="@style/StatLabel" android:text="@string/admin_stat_article" />
                        <TextView android:id="@+id/tvStatArticle" style="@style/StatValue" android:text="@string/admin_stat_article_value" />
                        <TextView style="@style/StatBadge" android:text="@string/admin_stat_article_badge" />
                    </LinearLayout>

                    <Space android:layout_width="12dp" android:layout_height="1dp" />

                    <LinearLayout style="@style/StatCard">
                        <FrameLayout android:layout_width="40dp" android:layout_height="40dp" android:background="@drawable/bg_icon_tile">
                            <ImageView android:layout_width="22dp" android:layout_height="22dp" android:layout_gravity="center" android:contentDescription="@null" android:src="@drawable/ic_trending_up" />
                        </FrameLayout>
                        <TextView style="@style/StatLabel" android:text="@string/admin_stat_log" />
                        <TextView android:id="@+id/tvStatLog" style="@style/StatValue" android:text="@string/admin_stat_log_value" />
                        <TextView style="@style/StatBadge" android:text="@string/admin_stat_log_badge" />
                    </LinearLayout>
                </LinearLayout>

                <!-- Growth chart -->
                <LinearLayout style="@style/ChartCard">

                    <TextView
                        style="@style/ChartCardTitle"
                        android:text="@string/admin_chart_growth" />

                    <com.example.nutriguideproject.ui.shared.chart.LineChartView
                        android:id="@+id/lineGrowth"
                        android:layout_width="match_parent"
                        android:layout_height="180dp"
                        android:layout_marginTop="12dp" />
                </LinearLayout>

                <!-- Aksi Cepat -->
                <TextView
                    style="@style/ProfileSectionLabel"
                    android:text="@string/admin_quick" />

<LinearLayout
                    android:id="@+id/rowAddFood"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_card"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:padding="14dp">

                    <FrameLayout style="@style/InfoIconTile" android:background="@drawable/bg_circle_lt_green">
                        <ImageView style="@style/InfoIcon" android:src="@drawable/ic_add" app:tint="@color/pastel_green" />
                    </FrameLayout>
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:layout_marginStart="12dp" android:orientation="vertical">
                        <TextView style="@style/InfoRowValue" android:text="@string/admin_add_food" />
                        <TextView style="@style/InfoRowLabel" android:text="@string/admin_add_food_sub" />
                    </LinearLayout>
                    <ImageView style="@style/InfoChevron" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/rowCreateArticle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:background="@drawable/bg_card"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:padding="14dp">

                    <FrameLayout style="@style/InfoIconTile" android:background="@drawable/bg_circle_lt_blue">
                        <ImageView style="@style/InfoIcon" android:src="@drawable/ic_document" app:tint="@color/pastel_blue" />
                    </FrameLayout>
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:layout_marginStart="12dp" android:orientation="vertical">
                        <TextView style="@style/InfoRowValue" android:text="@string/admin_create_article" />
                        <TextView style="@style/InfoRowLabel" android:text="@string/admin_create_article_sub" />
                    </LinearLayout>
                    <ImageView style="@style/InfoChevron" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/rowManageDb"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:background="@drawable/bg_card"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:padding="14dp">

                    <FrameLayout style="@style/InfoIconTile" android:background="@drawable/bg_circle_lt_orange">
                        <ImageView style="@style/InfoIcon" android:src="@drawable/ic_database" app:tint="@color/pastel_orange" />
                    </FrameLayout>
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:layout_marginStart="12dp" android:orientation="vertical">
                        <TextView style="@style/InfoRowValue" android:text="@string/admin_manage_db" />
                        <TextView style="@style/InfoRowLabel" android:text="@string/admin_manage_db_sub" />
                    </LinearLayout>
                    <ImageView style="@style/InfoChevron" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/rowUserList"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:background="@drawable/bg_card"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:padding="14dp">

                    <FrameLayout style="@style/InfoIconTile" android:background="@drawable/bg_circle_lt_purple">
                        <ImageView style="@style/InfoIcon" android:src="@drawable/ic_group" app:tint="@color/pastel_purple" />
                    </FrameLayout>
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:layout_marginStart="12dp" android:orientation="vertical">
                        <TextView style="@style/InfoRowValue" android:text="@string/admin_user_list" />
                        <TextView style="@style/InfoRowLabel" android:text="@string/admin_user_list_sub" />
                    </LinearLayout>
                    <ImageView style="@style/InfoChevron" />
                </LinearLayout>

            </LinearLayout>
        </LinearLayout>
    </ScrollView>

    <!-- Admin bottom nav -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/surface"
        android:elevation="12dp"
        android:orientation="horizontal"
        android:paddingHorizontal="8dp"
        android:paddingVertical="8dp">

        <!-- Dashboard (active) -->
        <LinearLayout
            android:id="@+id/adminNavDashboard"
            style="@style/NavItem">

            <LinearLayout
                style="@style/NavIconWrap"
                android:background="@drawable/bg_nav_active">

                <ImageView
                    style="@style/NavIcon"
                    android:contentDescription="@string/admin_nav_dashboard"
                    android:src="@drawable/ic_home"
                    app:tint="@color/nav_active" />
            </LinearLayout>

            <TextView
                style="@style/NavLabel"
                android:text="@string/admin_nav_dashboard"
                android:textColor="@color/nav_active"
                android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/adminNavFood"
            style="@style/NavItem">

            <LinearLayout style="@style/NavIconWrap">

                <ImageView
                    style="@style/NavIcon"
                    android:contentDescription="@string/admin_nav_food"
                    android:src="@drawable/ic_database"
                    app:tint="@color/nav_inactive" />
            </LinearLayout>

            <TextView
                style="@style/NavLabel"
                android:text="@string/admin_nav_food"
                android:textColor="@color/nav_inactive" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/adminNavSettings"
            style="@style/NavItem">

            <LinearLayout style="@style/NavIconWrap">

                <ImageView
                    style="@style/NavIcon"
                    android:contentDescription="@string/admin_nav_settings"
                    android:src="@drawable/ic_settings"
                    app:tint="@color/nav_inactive" />
            </LinearLayout>

            <TextView
                style="@style/NavLabel"
                android:text="@string/admin_nav_settings"
                android:textColor="@color/nav_inactive" />
        </LinearLayout>
    </LinearLayout>
</LinearLayout>

