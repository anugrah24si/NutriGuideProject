<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/articleRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/surface"
    android:orientation="vertical"
    tools:context=".ui.article.ArticleActivity">

    <!-- Toolbar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_auth_header"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="12dp"
        android:paddingVertical="14dp">

        <ImageView
            android:id="@+id/btnBack"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/article_toolbar_title"
            android:padding="8dp"
            android:src="@drawable/ic_arrow_back" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="4dp"
            android:text="@string/article_toolbar_title"
            android:textColor="@color/text_on_dark"
            android:textSize="18sp"
            android:textStyle="bold" />

        <ImageView
            android:id="@+id/btnShareTop"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/article_share"
            android:padding="8dp"
            android:src="@drawable/ic_share" />
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="18dp">

            <!-- Tag + read time -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_tag"
                    android:paddingHorizontal="10dp"
                    android:paddingVertical="4dp"
                    android:text="@string/article_tag"
                    android:textColor="@color/badge_green_text"
                    android:textSize="11sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="10dp"
                    android:text="@string/article_read_time"
                    android:textColor="@color/text_muted"
                    android:textSize="12sp" />
            </LinearLayout>

            <!-- Title -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="@string/article_title"
                android:textColor="@color/text_dark"
                android:textSize="24sp"
                android:textStyle="bold"
                android:lineSpacingExtra="2dp" />

            <!-- Author -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <FrameLayout
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:background="@drawable/bg_circle_green">

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:layout_gravity="center"
                        android:contentDescription="@null"
                        android:src="@drawable/ic_person"
                        app:tint="@color/white" />
                </FrameLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="10dp"
                    android:text="@string/article_author"
                    android:textColor="@color/text_dark"
                    android:textSize="14sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <!-- Hero -->
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="170dp"
                android:layout_marginTop="16dp"
                android:background="@drawable/bg_article_hero">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:text="🥗"
                    android:textSize="72sp" />
            </FrameLayout>

            <!-- Apa itu Stunting -->
            <TextView
                style="@style/ArticleSectionTitle"
                android:text="@string/article_sec1_title" />

            <TextView
                style="@style/ArticleBody"
                android:text="@string/article_sec1_body" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_fact_note"
                android:padding="14dp"
                android:text="@string/article_fact"
                android:textColor="#2C5C7A"
                android:textSize="13sp"
                android:textStyle="bold" />

            <!-- Mengapa Protein Penting -->
            <TextView
                style="@style/ArticleSectionTitle"
                android:text="@string/article_sec2_title" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_reco_item"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:padding="14dp">

                <FrameLayout
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:background="@drawable/bg_icon_tile">

                    <ImageView
                        android:layout_width="22dp"
                        android:layout_height="22dp"
                        android:layout_gravity="center"
                        android:contentDescription="@null"
                        android:src="@drawable/ic_apple_filled" />
                </FrameLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="12dp"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/article_point1_title"
                        android:textColor="@color/text_dark"
                        android:textSize="15sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:text="@string/article_point1_desc"
                        android:textColor="@color/text_muted"
                        android:textSize="13sp" />
                </LinearLayout>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:background="@drawable/bg_reco_item"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:padding="14dp">

                <FrameLayout
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:background="@drawable/bg_icon_tile">

                    <ImageView
                        android:layout_width="22dp"
                        android:layout_height="22dp"
                        android:layout_gravity="center"
                        android:contentDescription="@null"
                        android:src="@drawable/ic_chart" />
                </FrameLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="12dp"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/article_point2_title"
                        android:textColor="@color/text_dark"
                        android:textSize="15sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:text="@string/article_point2_desc"
                        android:textColor="@color/text_muted"
                        android:textSize="13sp" />
                </LinearLayout>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:background="@drawable/bg_reco_item"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:padding="14dp">

                <FrameLayout
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:background="@drawable/bg_icon_tile">

                    <ImageView
                        android:layout_width="22dp"
                        android:layout_height="22dp"
                        android:layout_gravity="center"
                        android:contentDescription="@null"
                        android:src="@drawable/ic_check"
                        app:tint="@color/white" />
                </FrameLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="12dp"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/article_point3_title"
                        android:textColor="@color/text_dark"
                        android:textSize="15sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:text="@string/article_point3_desc"
                        android:textColor="@color/text_muted"
                        android:textSize="13sp" />
                </LinearLayout>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:background="@drawable/bg_reco_item"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:padding="14dp">

                <FrameLayout
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:background="@drawable/bg_icon_tile">

                    <ImageView
                        android:layout_width="22dp"
                        android:layout_height="22dp"
                        android:layout_gravity="center"
                        android:contentDescription="@null"
                        android:src="@drawable/ic_book" />
                </FrameLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="12dp"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/article_point4_title"
                        android:textColor="@color/text_dark"
                        android:textSize="15sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:text="@string/article_point4_desc"
                        android:textColor="@color/text_muted"
                        android:textSize="13sp" />
                </LinearLayout>
            </LinearLayout>

            <!-- Sumber Protein -->
            <TextView
                style="@style/ArticleSectionTitle"
                android:text="@string/article_sec3_title" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:baselineAligned="false"
                android:orientation="horizontal">

                <LinearLayout style="@style/SourceCard">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="🥚" android:textSize="32sp" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="6dp" android:text="Telur" android:textColor="@color/text_dark" android:textSize="14sp" android:textStyle="bold" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="6g protein / butir" android:textColor="@color/text_muted" android:textSize="11sp" />
                </LinearLayout>

                <Space android:layout_width="10dp" android:layout_height="1dp" />

                <LinearLayout style="@style/SourceCard">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="🍗" android:textSize="32sp" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="6dp" android:text="Ayam" android:textColor="@color/text_dark" android:textSize="14sp" android:textStyle="bold" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="25g protein / 100g" android:textColor="@color/text_muted" android:textSize="11sp" />
                </LinearLayout>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:baselineAligned="false"
                android:orientation="horizontal">

                <LinearLayout style="@style/SourceCard">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="🫘" android:textSize="32sp" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="6dp" android:text="Tempe" android:textColor="@color/text_dark" android:textSize="14sp" android:textStyle="bold" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="14g protein / porsi" android:textColor="@color/text_muted" android:textSize="11sp" />
                </LinearLayout>

                <Space android:layout_width="10dp" android:layout_height="1dp" />

                <LinearLayout style="@style/SourceCard">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="🐟" android:textSize="32sp" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="6dp" android:text="Ikan" android:textColor="@color/text_dark" android:textSize="14sp" android:textStyle="bold" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="20g protein / 100g" android:textColor="@color/text_muted" android:textSize="11sp" />
                </LinearLayout>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:baselineAligned="false"
                android:orientation="horizontal">

                <LinearLayout style="@style/SourceCard">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="🥛" android:textSize="32sp" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="6dp" android:text="Susu" android:textColor="@color/text_dark" android:textSize="14sp" android:textStyle="bold" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="8g protein / gelas" android:textColor="@color/text_muted" android:textSize="11sp" />
                </LinearLayout>

                <Space android:layout_width="10dp" android:layout_height="1dp" />

                <LinearLayout style="@style/SourceCard">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="🥜" android:textSize="32sp" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="6dp" android:text="Kacang" android:textColor="@color/text_dark" android:textSize="14sp" android:textStyle="bold" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="9g protein / porsi" android:textColor="@color/text_muted" android:textSize="11sp" />
                </LinearLayout>
            </LinearLayout>

            <!-- Rekomendasi Asupan -->
            <TextView
                style="@style/ArticleSectionTitle"
                android:text="@string/article_sec4_title" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_reco_item"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:padding="14dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/article_reco1_title"
                    android:textColor="@color/text_dark"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/article_reco1_value"
                    android:textColor="@color/green_dark"
                    android:textSize="13sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:background="@drawable/bg_reco_item"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:padding="14dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/article_reco2_title"
                    android:textColor="@color/text_dark"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/article_reco2_value"
                    android:textColor="@color/green_dark"
                    android:textSize="13sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:background="@drawable/bg_reco_item"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:padding="14dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/article_reco3_title"
                    android:textColor="@color/text_dark"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/article_reco3_value"
                    android:textColor="@color/green_dark"
                    android:textSize="13sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <!-- Tips -->
            <TextView
                style="@style/ArticleSectionTitle"
                android:text="@string/article_sec5_title" />

            <TextView
                style="@style/ArticleBody"
                android:text="@string/article_sec5_body" />

            <!-- Kesimpulan -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:background="@drawable/bg_highlight_box"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/article_conclusion_title"
                    android:textColor="@color/green_dark"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="@string/article_conclusion_body"
                    android:textColor="@color/text_dark"
                    android:textSize="14sp"
                    android:lineSpacingExtra="3dp" />
            </LinearLayout>

            <!-- Action buttons -->
            <Button
                android:id="@+id/btnSave"
                style="@style/PrimaryGreenButton"
                android:layout_marginTop="20dp"
                android:text="@string/article_save" />

            <Button
                android:id="@+id/btnShare"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_button_outline"
                android:stateListAnimator="@null"
                android:text="@string/article_share"
                android:textAllCaps="false"
                android:textColor="@color/text_dark"
                android:textSize="16sp"
                android:textStyle="bold" />

            <!-- Artikel Terkait -->
            <TextView
                style="@style/ArticleSectionTitle"
                android:text="@string/article_related" />

            <LinearLayout style="@style/FoodLogCard">

                <FrameLayout style="@style/FoodLogIconTile">

                    <ImageView
                        style="@style/FoodLogIcon"
                        android:src="@drawable/ic_book" />
                </FrameLayout>

                <LinearLayout style="@style/FoodLogText">

                    <TextView
                        style="@style/FoodLogName"
                        android:text="@string/article_related1_title" />

                    <TextView
                        style="@style/FoodLogDesc"
                        android:text="@string/article_related1_read" />
                </LinearLayout>
            </LinearLayout>

            <LinearLayout style="@style/FoodLogCard">

                <FrameLayout style="@style/FoodLogIconTile">

                    <ImageView
                        style="@style/FoodLogIcon"
                        android:src="@drawable/ic_book" />
                </FrameLayout>

                <LinearLayout style="@style/FoodLogText">

                    <TextView
                        style="@style/FoodLogName"
                        android:text="@string/article_related2_title" />

                    <TextView
                        style="@style/FoodLogDesc"
                        android:text="@string/article_related2_read" />
                </LinearLayout>
            </LinearLayout>

        </LinearLayout>
    </ScrollView>
</LinearLayout>
