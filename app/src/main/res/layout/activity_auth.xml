<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/authRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/surface"
    android:fillViewport="true"
    tools:context=".ui.auth.AuthActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_auth_header"
            android:gravity="center"
            android:orientation="vertical"
            android:paddingTop="40dp"
            android:paddingBottom="32dp">

            <FrameLayout
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:background="@drawable/bg_logo_circle_light">

                <ImageView
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:layout_gravity="center"
                    android:contentDescription="@string/cd_logo"
                    android:src="@drawable/ic_seedling" />
            </FrameLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:fontFamily="sans-serif-light"
                android:text="@string/welcome_title"
                android:textColor="@color/text_on_dark"
                android:textSize="32sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="@string/auth_welcome_back"
                android:textColor="@color/text_on_dark_muted"
                android:textSize="16sp" />
        </LinearLayout>

        <!-- Form area -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <!-- Tab toggle -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_tab_track"
                android:orientation="horizontal"
                android:padding="4dp">

                <TextView
                    android:id="@+id/tabLogin"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:background="@drawable/bg_tab_active"
                    android:gravity="center"
                    android:paddingVertical="12dp"
                    android:text="@string/auth_tab_login"
                    android:textColor="@color/text_dark"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tabRegister"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:background="@android:color/transparent"
                    android:gravity="center"
                    android:paddingVertical="12dp"
                    android:text="@string/auth_tab_register"
                    android:textColor="@color/text_muted" />
            </LinearLayout>

            <!-- Nama Lengkap (register only) -->
            <LinearLayout
                android:id="@+id/nameGroup"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <TextView
                    style="@style/FieldLabel"
                    android:text="@string/auth_label_name" />

                <LinearLayout
                    style="@style/FieldBox">

                    <ImageView
                        style="@style/FieldIcon"
                        android:src="@drawable/ic_person" />

                    <EditText
                        android:id="@+id/inputName"
                        style="@style/FieldInput"
                        android:hint="@string/auth_hint_name"
                        android:inputType="textPersonName"
                        android:autofillHints="name" />
                </LinearLayout>
            </LinearLayout>

            <!-- Email -->
            <TextView
                style="@style/FieldLabel"
                android:text="@string/auth_label_email" />

            <LinearLayout style="@style/FieldBox">

                <ImageView
                    style="@style/FieldIcon"
                    android:src="@drawable/ic_email" />

                <EditText
                    android:id="@+id/inputEmail"
                    style="@style/FieldInput"
                    android:hint="@string/auth_hint_email"
                    android:inputType="textEmailAddress"
                    android:autofillHints="emailAddress" />
            </LinearLayout>

            <!-- Password + tombol lihat/sembunyikan -->
            <TextView
                style="@style/FieldLabel"
                android:text="@string/auth_label_password" />

            <LinearLayout style="@style/FieldBox">

                <ImageView
                    style="@style/FieldIcon"
                    android:src="@drawable/ic_lock" />

                <EditText
                    android:id="@+id/inputPassword"
                    style="@style/FieldInput"
                    android:hint="@string/auth_hint_password"
                    android:inputType="textPassword"
                    android:autofillHints="password" />

                <!-- Toggle: tap untuk show/hide password -->
                <ImageButton
                    android:id="@+id/btnTogglePassword"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="@string/auth_show_password"
                    android:padding="8dp"
                    android:scaleType="centerInside"
                    android:src="@drawable/ic_visibility_off" />
            </LinearLayout>

            <!-- Login buttons -->
            <LinearLayout
                android:id="@+id/loginButtons"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:orientation="vertical">

                <Button
                    android:id="@+id/btnLoginUser"
                    style="@style/PrimaryGreenButton"
                    android:text="@string/auth_login_user" />

                <Button
                    android:id="@+id/btnLoginAdmin"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:layout_marginTop="12dp"
                    android:background="@drawable/bg_button_outline"
                    android:stateListAnimator="@null"
                    android:text="@string/auth_login_admin"
                    android:textAllCaps="false"
                    android:textColor="@color/text_dark"
                    android:textSize="16sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <!-- Register button -->
            <Button
                android:id="@+id/btnRegister"
                style="@style/PrimaryGreenButton"
                android:layout_marginTop="24dp"
                android:text="@string/auth_register"
                android:visibility="gone" />
        </LinearLayout>
    </LinearLayout>
</ScrollView>
